{
  "name": "{{PROJECT_NAME}}",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "format": "biome check --write .",
    "knip": "knip",
    "check": "pnpm biome check --write . && pnpm typecheck && pnpm test && pnpm knip",
    "changeset": "changeset",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.50.0",
    "knip": "^5.0.0",
    "lefthook": "^1.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

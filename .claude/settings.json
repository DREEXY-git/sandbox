{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm test:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm biome:*)",
      "Bash(pnpm knip)",
      "Bash(pnpm build)",
      "Bash(pnpm dlx:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(gh workflow:*)"
    ],
    "ask": ["Bash(git push:*)", "Bash(gh pr merge:*)", "Bash(vercel:*)", "Bash(rm:*)"],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Read(./**/secrets/**)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm biome check --write --no-errors-on-unmatched \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
